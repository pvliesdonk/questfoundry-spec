{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/art_plan.schema.json",
  "title": "Art Plan",
  "type": "object",
  "required": ["version","items"],
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "subject", "priority"],
        "properties": {
          "id": {"type": "string"},
          "subject": {"type": "string"},
          "ref": {"type": "string"},
          "priority": {"type": "integer", "minimum": 1, "maximum": 5},
          "framing": {"type": "string"},
          "style": {"type": "string"},
          "set_id": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": false
}

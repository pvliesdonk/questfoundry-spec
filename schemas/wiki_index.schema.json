{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Wiki Index",
  "type": "object",
  "required": ["entities"],
  "properties": {
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "path"],
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "path": {"type": "string"}
        }
      }
    }
  },
  "additionalProperties": false
}

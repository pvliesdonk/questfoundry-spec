{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Plot Map Graph",
  "type": "object",
  "required": ["nodes", "edges"],
  "additionalProperties": false,
  "properties": {
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind"],
        "properties": {
          "id": {"type": "string"},
          "kind": {"type": "string", "enum": ["beat", "choice", "rejoin"]}
        }
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "kind"],
        "properties": {
          "from": {"type": "string"},
          "to": {"type": "string"},
          "kind": {"type": "string", "enum": ["progress", "choice", "rejoin"]}
        }
      }
    },
    "invariants": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "dead_ends_allowed": {"type": "boolean", "default": false},
        "max_soft_rejoin_distance": {"type": "integer"}
      }
    }
  }
}

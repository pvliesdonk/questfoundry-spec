{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/section.schema.json",
  "title": "Section",
  "type": "object",
  "required": ["version","id", "beat_ref", "text"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "id": {"type": "string"},
    "beat_ref": {
      "type": "object",
      "required": ["thread_id", "beat_id"],
      "properties": {
        "thread_id": {"type": "string"},
        "beat_id": {"type": "string"}
      },
      "additionalProperties": false
    },
    "text": {"type": "string"},
    "meta": {
      "type": "object",
      "properties": {
        "wordcount": {"type": "integer"},
        "pov": {"type": "string"},
        "tense": {"type": "string"},
        "characters_present": {"type": "array", "items": {"type": "string"}},
        "continuity": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  }
}

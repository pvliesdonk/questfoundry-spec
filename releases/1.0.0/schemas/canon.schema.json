{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/canon.schema.json",
  "title": "World Canon",
  "type": "object",
  "required": ["version","entities"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "name"],
        "properties": {
          "id": {"type": "string"},
          "kind": {"type": "string", "enum": ["character", "faction", "location", "relic", "ship", "infrastructure", "organization", "object"]},
          "name": {"type": "string"},
          "summary": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}},
          "traits": {"type": "object"},
          "motivation": {"type": "string"},
          "source_refs": {"type": "array", "items": {"type": "string"}}
        }
      }
    }
  }
}

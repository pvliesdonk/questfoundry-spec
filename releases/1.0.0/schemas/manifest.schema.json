{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/manifest.schema.json",
  "title": "Build Manifest",
  "type": "object",
  "required": ["version","title", "chapters", "plot_index"],
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "title": {"type": "string"},
    "chapters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title"],
        "properties": {
          "id": {"type": "string"},
          "title": {"type": "string"},
          "section_path": {"type": "string"},
          "art_ids": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "plot_index": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"}
      }
    },
    "wordcount": {"type": "integer"},
    "art_ratio": {"type": "number"}
  },
  "additionalProperties": false
}

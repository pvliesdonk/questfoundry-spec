{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/research_packet.schema.json",
  "title": "Research Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["version","id", "session_id", "issued_at", "answers"],
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "id": {"type": "string"},
    "session_id": {"type": "string"},
    "issued_at": {"type": "string", "format": "date-time"},
    "loop_state": {"type": "string", "enum": ["drafting", "revision", "stabilizing", "stable"]},
    "cycle": {"type": "integer", "minimum": 0},
    "answers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["q", "claim", "confidence", "evidence"],
        "properties": {
          "q": {"type": "string"},
          "claim": {"type": "string"},
          "confidence": {"type": "number", "minimum": 0, "maximum": 1},
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["source", "support"],
              "properties": {
                "source": {
                  "type": "object",
                  "required": ["title", "url"],
                  "properties": {
                    "title": {"type": "string"},
                    "url": {"type": "string"},
                    "publisher": {"type": "string"},
                    "date": {"type": "string"}
                  }
                },
                "support": {"type": "string", "enum": ["supports", "contradicts", "neutral"]},
                "quote": {"type": "string"},
                "note": {"type": "string"}
              }
            }
          },
          "resolution": {"type": "string", "enum": ["use", "discard", "defer"]},
          "routing": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "bibliography": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": {"type": "string"},
          "url": {"type": "string"},
          "publisher": {"type": "string"},
          "date": {"type": "string"}
        }
      }
    }
  }
}

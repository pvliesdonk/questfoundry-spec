{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://liesdonk.nl/questfoundry/v1.0.0/schemas/art_manifest.schema.json",
  "title": "Art Manifest",
  "type": "object",
  "required": ["version","images"],
  "properties": {
    "version": {"type": "string", "const": "1.0.0"},
    "images": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "subject"],
        "properties": {
          "id": {"type": "string"},
          "path": {"type": "string"},
          "subject": {"type": "string"},
          "plan_id": {"type": "string"},
          "meta": {
            "type": "object",
            "properties": {
              "prompt": {"type": "string"},
              "seed": {"type": "string"},
              "model": {"type": "string"},
              "resolution": {"type": "string"}
            },
            "additionalProperties": false
          },
          "provider_meta": {
            "type": "object",
            "description": "Provider-specific metadata (e.g., SDXL, Comfy, Imagen, DALL·E).",
            "additionalProperties": true
          }
        }
      }
    }
  },
  "additionalProperties": false
}
